{
  "name": "jewware",
  "author": "JewWare",
  "version": "6.1.0", 
  "description": "JewWare desktop app",
  "scripts": {
    "start": "electron .",
    "build": "./build.sh"
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.jewware.app",
    "productName": "JewWare",
    "asar": true,
    "icon": "assets/icon.png",
    "files": [
      "assets/**/*",
      "index.html",
      "index.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../website",
        "to": "website",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraFiles": []
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
